{
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/index.html",
      "destination": "/",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/wp-login.php",  "destination": "/hp?trap=wp-login" },
    { "source": "/admin",         "destination": "/hp?trap=admin" },
    { "source": "/.env",          "destination": "/hp?trap=dotenv" },
    { "source": "/phpmyadmin",    "destination": "/hp?trap=phpmyadmin" },
    { "source": "/config.php",    "destination": "/hp?trap=config" },
    { "source": "/.git/(.*)",     "destination": "/hp?trap=git" },
    { "source": "/backup(.*)",    "destination": "/hp?trap=backup" },
    { "source": "/xmlrpc.php",    "destination": "/hp?trap=xmlrpc" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options",        "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy",        "value": "strict-origin-when-cross-origin" },
        { "key": "X-DNS-Prefetch-Control", "value": "off" },
        { "key": "Cross-Origin-Opener-Policy",   "value": "same-origin" },
        { "key": "Cross-Origin-Resource-Policy",  "value": "same-origin" },
        { "key": "Permissions-Policy",     "value": "camera=(), microphone=(), geolocation=(), payment=(), usb=(), interest-cohort=()" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; base-uri 'self'; frame-ancestors 'none'; object-src 'none'; form-action 'self'; img-src 'self' data: https://challenges.cloudflare.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; script-src 'self' 'unsafe-inline' https://challenges.cloudflare.com; connect-src 'self' https://challenges.cloudflare.com https://aegis8-agent.christianmora705.workers.dev; frame-src https://challenges.cloudflare.com; upgrade-insecure-requests"
        }
      ]
    }
  ]
}
